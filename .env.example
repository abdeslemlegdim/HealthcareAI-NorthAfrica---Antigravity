# =================================
# Application Configuration
# =================================
APP_NAME="Healthcare AI Assistant"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=true
LOG_LEVEL="INFO"

# =================================
# API Configuration
# =================================
API_HOST="0.0.0.0"
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# CORS Configuration
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing
# Add your frontend URLs here (development and production)
# Examples:
#   Development: http://localhost:3000,http://localhost:5173
#   Production: https://yourdomain.com,https://app.yourdomain.com
# IMPORTANT: In production, restrict this to your actual frontend domains only
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:8501,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://127.0.0.1:5177"

# =================================
# Security & Authentication
# =================================
# General application secret key for encryption and signing
SECRET_KEY="your-super-secret-key-change-this-in-production"

# JWT Authentication Configuration
# IMPORTANT: Generate a secure random key for production using:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Or using OpenSSL:
#   openssl rand -base64 32
# This key is used to sign JWT tokens - keep it secret and never commit to version control
JWT_SECRET_KEY="jwt-secret-key-change-this-in-production"

# JWT algorithm for token signing (HS256 is recommended for symmetric signing)
JWT_ALGORITHM="HS256"

# Access token expiration time in minutes (default: 30 minutes)
# Short-lived tokens reduce the risk of token theft
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time in days (default: 7 days)
# Used to obtain new access tokens without re-authentication
# Extended to 30 days when "Remember Me" is selected during login
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_REMEMBER_ME_DAYS=30

# =================================
# Rate Limiting Configuration
# =================================
# Login rate limiting (prevents brute force attacks)
RATE_LIMIT_LOGIN_ATTEMPTS=5  # Max login attempts per email
RATE_LIMIT_LOGIN_WINDOW_MINUTES=15  # Time window for login attempts

# Registration rate limiting (prevents spam)
RATE_LIMIT_REGISTER_ATTEMPTS=10  # Max registrations per IP
RATE_LIMIT_REGISTER_WINDOW_MINUTES=60  # Time window for registrations

# Token refresh rate limiting
RATE_LIMIT_REFRESH_ATTEMPTS=20  # Max token refreshes per user
RATE_LIMIT_REFRESH_WINDOW_MINUTES=60  # Time window for token refreshes

# =================================
# HTTPS and Security Headers
# =================================
# IMPORTANT: Enable these in production for enhanced security
# HTTPS enforcement (redirect HTTP to HTTPS)
HTTPS_ONLY=false  # Set to true in production

# Secure cookie flags (requires HTTPS)
SECURE_COOKIES=false  # Set to true in production with HTTPS
HTTPONLY_COOKIES=true  # Prevents JavaScript access to cookies
SAMESITE_COOKIES="lax"  # Options: "strict", "lax", "none" (use "strict" for maximum security)

# =================================
# Database Configuration
# =================================
# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/healthcare_ai"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=""

# Vector Database (Qdrant)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# =================================
# ML Model Paths
# =================================
# Medical Imaging
MEDICAL_IMAGE_MODEL_PATH="models/efficientnet_chest.pt"
GRADCAM_LAYER_NAME="features.7"

# NLP & RAG
EMBEDDING_MODEL_NAME="sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
LLM_MODEL_NAME="Qwen/Qwen2.5-7B-Instruct"
RERANKER_MODEL_NAME="cross-encoder/ms-marco-MiniLM-L6-v2"

# Vital Signs
RPPG_MODEL_PATH="models/rppg_model.pt"

# =================================
# Data Paths
# =================================
DATA_RAW_DIR="data/raw"
DATA_PROCESSED_DIR="data/processed"
MEDICAL_KG_DIR="data/medical_kg"
MODELS_DIR="models"

# =================================
# Medical Knowledge Graph
# =================================
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-neo4j-password"

# =================================
# MLOps Configuration
# =================================
# MLflow
MLFLOW_TRACKING_URI="http://localhost:5000"
MLFLOW_EXPERIMENT_NAME="healthcare-ai-experiments"

# Weights & Biases
WANDB_API_KEY="your-wandb-api-key"
WANDB_PROJECT="healthcare-ai-north-africa"
WANDB_ENTITY="your-wandb-username"

# =================================
# External APIs
# =================================
# OpenAI (optional, for baseline comparison)
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_BASE_URL="https://api.openai.com/v1"

# OpenRouter (optional, recommended for multi-model fallback)
OPENROUTER_API_KEY="sk-or-your-openrouter-key"
OPENROUTER_SITE_URL="http://localhost:3005"
OPENROUTER_APP_NAME="Healthcare AI Assistant"

# LLM API routing
USE_RAG=true
USE_LLM_API=true
LLM_API_ENDPOINT=""  # Optional explicit endpoint (OpenAI-compatible chat/completions)
LLM_API_MODELS="openai/gpt-4o-mini,google/gemini-2.0-flash-001,qwen/qwen-2.5-72b-instruct"

# Hugging Face
HUGGINGFACE_TOKEN="your-hf-token"

# Imaging APIs (optional, for trained remote models)
USE_IMAGING_API=false
IMAGING_API_ENDPOINT=""
IMAGING_EXPLAIN_API_ENDPOINT=""
IMAGING_API_KEY=""

# =================================
# Monitoring
# =================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# =================================
# Language Configuration
# =================================
SUPPORTED_LANGUAGES="ar,fr,en"  # Arabic, French, English
DEFAULT_LANGUAGE="ar"

# =================================
# Medical Dataset Configuration
# =================================
CHEST_XRAY_DATASET_PATH="data/raw/chest_xray"
COVID_DATASET_PATH="data/raw/covid19"
TBX11K_DATASET_PATH="data/raw/tbx11k"

# =================================
# Deployment
# =================================
DOCKER_REGISTRY="your-registry.com"
DOCKER_IMAGE_TAG="latest"

# =================================
# Feature Flags
# =================================
ENABLE_MEDICAL_IMAGING=true
ENABLE_RAG_SYSTEM=true
ENABLE_VITAL_SIGNS=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_EXPLAINABILITY=true
ENABLE_AUTHENTICATION=true  # Enable/disable authentication system (set to false for backward compatibility)

# =================================
# Performance
# =================================
MAX_BATCH_SIZE=32
NUM_WORKERS=4
DEVICE="cuda"  # cuda, cpu, mps
MIXED_PRECISION=true

# =================================
# HIPAA Compliance
# =================================
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_ENCRYPTION=true
PHI_ANONYMIZATION=true
